{
  "name": "whatdoumeme",
  "version": "1.2.0",
  "author": "breezertwo",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=22.14.0",
    "yarn": "1.x"
  },
  "scripts": {
    "backend": "yarn workspace @whatdoumeme/server",
    "frontend": "yarn workspace @whatdoumeme/client",
    "dev": "concurrently \"yarn backend:dev\" \"yarn frontend:dev\"",
    "backend:dev": "yarn backend dev",
    "backend:debug": "yarn backend dev:debug",
    "frontend:dev": "yarn frontend dev",
    "frontend:build": "yarn frontend build"
  },
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "concurrently": "9.2.1",
    "eslint": "10.0.1",
    "eslint-config-prettier": "10.1.8",
    "typescript-eslint": "8.56.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "yarn-deduplicate": "6.0.2"
  }
}
