    "module": "ESNext",
    "target": "ESNext",
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["vite/client", "vite-plugin-svgr/client"],
  },
  "include": ["src/**/*", "vite.config.ts"],
}
